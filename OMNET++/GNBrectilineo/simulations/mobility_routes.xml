<?xml version="1.0" encoding="UTF-8"?>
<movements>
    <!-- Ruta 1: Diagonal con paradas -->
    <route id="route1">
        <set x="100" y="100" speed="0"/>
        <wait t="2"/>
        <move x="300" y="300" speed="15"/>
        <wait t="3"/>
        <move x="600" y="600" speed="20"/>
        <wait t="2"/>
        <move x="1000" y="700" speed="25"/>
        <wait t="5"/>
        <move x="100" y="100" speed="30"/>
    </route>
    
    <!-- Ruta 2: Zigzag -->
    <route id="route2">
        <set x="200" y="100" speed="0"/>
        <move x="400" y="300" speed="18"/>
        <move x="200" y="500" speed="18"/>
        <move x="600" y="700" speed="18"/>
        <move x="1000" y="500" speed="18"/>
        <move x="800" y="300" speed="18"/>
        <move x="1000" y="100" speed="18"/>
        <move x="200" y="100" speed="22"/>
    </route>
    
    <!-- Ruta 3: Recorrido en L -->
    <route id="route3">
        <set x="100" y="100" speed="0"/>
        <move x="100" y="700" speed="20"/>
        <wait t="3"/>
        <move x="1100" y="700" speed="20"/>
        <wait t="3"/>
        <move x="100" y="100" speed="25"/>
    </route>
    
    <!-- Ruta 4: Patrulla perimetral -->
    <route id="route4">
        <set x="50" y="50" speed="0"/>
        <move x="1150" y="50" speed="25"/>
        <move x="1150" y="750" speed="25"/>
        <move x="50" y="750" speed="25"/>
        <move x="50" y="50" speed="25"/>
    </route>
</movements>